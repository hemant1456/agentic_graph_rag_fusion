# Copy this file to .env and fill in real keys. .env is gitignored.
# All providers are free-tier; the gateway rotates through them automatically.

# Required for the LLM gateway provider chain.
# Only the keys whose providers you want active need values.
GROQ_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_API_KEY=
NVIDIA_API_KEY=

# Optional — only used when JUDGE_PROVIDER=openai (paid fallback for eval).
OPENAI_API_KEY=

# Optional — only used by step_01 direct Anthropic fallback (now retired
# since step_01 routes through the gateway, but Claude users may still set it).
ANTHROPIC_API_KEY=

# Optional — HuggingFace Hub token. Sentence-transformers + cross-encoder
# downloads work without it but rate-limited; setting one lifts the cap.
HF_TOKEN=

# Optional — override gateway base URL (default http://localhost:8100).
# LLM_GATEWAY_V2_URL=http://localhost:8100

# Optional — judge config overrides (defaults are sensible).
# JUDGE_PROVIDER=gateway          # gateway | openai
# JUDGE_PROVIDERS=cerebras,groq,gemini,nvidia
# JUDGE_MODEL=gpt-4o-mini         # only used with JUDGE_PROVIDER=openai
